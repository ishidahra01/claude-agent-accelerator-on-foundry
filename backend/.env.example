CLAUDE_CODE_USE_FOUNDRY=1

# Set one of the following. BASE_URL takes precedence if both are set.
ANTHROPIC_FOUNDRY_RESOURCE=
ANTHROPIC_FOUNDRY_BASE_URL=

# Optional. When set, Claude Code uses API key authentication.
# Leave unset for Entra ID authentication via Azure CLI, managed identity, or other DefaultAzureCredential sources.
ANTHROPIC_FOUNDRY_API_KEY=

# Pin deployment names to avoid breakage when Anthropic ships new model aliases.
ANTHROPIC_DEFAULT_OPUS_MODEL=claude-opus-4-6
ANTHROPIC_DEFAULT_SONNET_MODEL=claude-sonnet-4-6
ANTHROPIC_DEFAULT_HAIKU_MODEL=claude-haiku-4-5

CLAUDE_MODEL=sonnet
CLAUDE_MAX_TURNS=12
CLAUDE_EFFORT=high
CLAUDE_PERMISSION_MODE=dontAsk
CLAUDE_CODE_USE_POWERSHELL_TOOL=1
AGENT_WORKSPACE_ROOT=work
AZURE_AI_PROJECT_ENDPOINT=